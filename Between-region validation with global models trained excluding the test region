import pandas as pd
import numpy as np
from sklearn.model_selection import GridSearchCV
from sklearn.linear_model import LogisticRegression
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import roc_auc_score
from sklearn.utils import resample
from sklearn.calibration import calibration_curve

# ---------------------------
# 1. データセットの読み込みなどの準備
# ---------------------------
data = pd.read_csv('/content/GUSTO_sterberg.csv')
unique_regl = sorted(data['REGL'].unique())  # テスト地域は 1～16 と仮定

# 各正則化法のハイパーパラメータグリッドの設定
param_grid_lasso   = {'C': np.logspace(-3, 3, 7), 'penalty': ['l1'],         'solver': ['liblinear']}
param_grid_ridge   = {'C': np.logspace(-3, 3, 7), 'penalty': ['l2'],         'solver': ['lbfgs']}
param_grid_elastic = {'C': np.logspace(-3, 3, 7), 'penalty': ['elasticnet'], 'solver': ['saga'], 'l1_ratio': [0.1, 0.5, 0.9]}

# 結果格納用の辞書（各評価対象地域ごとのブートストラップ結果を格納）
bootstrap_results = {}

# 各モデルの標準化偏回帰係数をまとめるリスト
coeff_list = []

# ---------------------------
# 2. 各評価対象地域ごとに、該当地域を除いた全データでモデル構築と評価
# ---------------------------
for regl_test in unique_regl:
    print(f"Evaluating test region: {regl_test}")
    # 訓練データ：評価対象地域を除外
    train_data = data[data['REGL'] != regl_test].copy()
    # テストデータ：評価対象地域のみ
    test_data = data[data['REGL'] == regl_test].copy()
    
    # 特徴量と目的変数の設定（'REGL' は除外）
    X_train = train_data.drop(columns=['DAY30', 'REGL'])
    y_train = train_data['DAY30']
    X_test  = test_data.drop(columns=['DAY30', 'REGL'])
    y_test  = test_data['DAY30']
    
    # 特徴量の標準化
    scaler = StandardScaler()
    X_train_scaled = scaler.fit_transform(X_train)
    X_test_scaled = scaler.transform(X_test)
    
    # 4種類のモデル（LASSO, Ridge, ElasticNet, Unpenalized）の学習
    models = {
        'LASSO': GridSearchCV(
            LogisticRegression(max_iter=10000),
            param_grid=param_grid_lasso, cv=5, scoring='neg_log_loss'
        ).fit(X_train_scaled, y_train),
        
        'Ridge': GridSearchCV(
            LogisticRegression(max_iter=10000),
            param_grid=param_grid_ridge, cv=5, scoring='neg_log_loss'
        ).fit(X_train_scaled, y_train),
        
        'ElasticNet': GridSearchCV(
            LogisticRegression(max_iter=10000),
            param_grid=param_grid_elastic, cv=5, scoring='neg_log_loss'
        ).fit(X_train_scaled, y_train),
        
        # 正則化なしモデル：GridSearchCV を使わず単一のモデルとして学習
        'Unpenalized': LogisticRegression(max_iter=10000, penalty=None, solver='lbfgs').fit(X_train_scaled, y_train)
    }
    
    # ---------------------------
    # 2-1. 各モデルの最良推定器または学習済み推定器の標準化偏回帰係数を保存
    # ---------------------------
    for model_name, model in models.items():
        if hasattr(model, "best_estimator_"):
            coef_values = model.best_estimator_.coef_[0]
        else:
            coef_values = model.coef_[0]
        coeff_dict = {'Excluded_Test_Region': regl_test, 'Model': model_name}
        for i, feature in enumerate(X_train.columns):
            coeff_dict[feature] = coef_values[i]
        coeff_list.append(coeff_dict)
    
    # ---------------------------
    # 3. 各モデルについてブートストラップ評価（1000回）を実施
    # ---------------------------
    bootstrap_results.setdefault(regl_test, {})  # 評価対象地域ごとの辞書を初期化
    
    for model_name, model in models.items():
        aucs = []
        slopes = []
        intercepts = []
        
        for i in range(1000):
            X_test_bs, y_test_bs = resample(X_test_scaled, y_test, random_state=i)
            # GridSearchCVの場合は best_estimator_ を用いる
            if hasattr(model, "best_estimator_"):
                y_pred_prob = model.best_estimator_.predict_proba(X_test_bs)[:, 1]
            else:
                y_pred_prob = model.predict_proba(X_test_bs)[:, 1]
            
            aucs.append(roc_auc_score(y_test_bs, y_pred_prob))
            
            # キャリブレーションカーブから傾きと切片を取得
            frac_pos, mean_pred_val = calibration_curve(y_test_bs, y_pred_prob, n_bins=10)
            slope, intercept = np.polyfit(mean_pred_val, frac_pos, 1)
            slopes.append(slope)
            intercepts.append(intercept)
        
        bootstrap_results[regl_test][model_name] = {
            'AUROC': aucs,
            'CalibrationSlope': slopes,
            'CalibrationIntercept': intercepts
        }

# ---------------------------
# 4. 評価指標ごとに1つのCSVファイルとして出力（AUPRC と Brier は除外）
# ---------------------------
# 以下、各CSVの列名は "Model_excludeRegion<test_region>" としています
metrics = ['AUROC', 'CalibrationSlope', 'CalibrationIntercept']
metric_results = {metric: {} for metric in metrics}

for regl_test in bootstrap_results:
    for model_name in bootstrap_results[regl_test]:
        col_key = f"{model_name}_excludeRegion{regl_test}"
        for metric in metrics:
            metric_results[metric][col_key] = bootstrap_results[regl_test][model_name][metric]

for metric, result_dict in metric_results.items():
    df_metric = pd.DataFrame(result_dict)
    output_filename = f"{metric}_global_excluded.csv"
    df_metric.to_csv(output_filename, index=False)
    print(f"{metric} results saved to {output_filename}")

# ---------------------------
# 5. 全モデル（評価対象地域を除いたモデル）の標準化偏回帰係数を CSV として出力
# ---------------------------
coeff_df = pd.DataFrame(coeff_list)
coeff_df.to_csv("all_coefficients_global_excluded.csv", index=False)
print("All coefficients saved to all_coefficients_global_excluded.csv")
