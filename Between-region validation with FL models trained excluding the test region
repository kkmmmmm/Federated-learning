import pandas as pd
import numpy as np
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import roc_auc_score
from sklearn.utils import resample
from sklearn.calibration import calibration_curve

# ---------------------------
# 1. データセットの読み込み
# ---------------------------
data = pd.read_csv('/content/GUSTO_sterberg.csv')
unique_regl = sorted(data['REGL'].unique())

# ---------------------------
# 2. FedProxモデルの係数と切片をExcelから取得
# ---------------------------
df_coeff = pd.read_excel('/content/係数区分.xlsx', sheet_name='Sheet1')
model_names = df_coeff['モデル区分'].tolist()
fedprox_models = {}

for i, row in df_coeff.iterrows():
    model_key = row['モデル区分']
    fedprox_models[model_key] = {
        'coefficients': row.drop(labels=['モデル区分', 'intercept']).to_dict(),
        'intercept': row['intercept']
    }

# ---------------------------
# 3. 結果格納用の辞書（点推定値と95%CI）
# ---------------------------
bootstrap_summary = {metric: {} for metric in ['AUROC', 'CalibrationSlope', 'CalibrationIntercept']}

# ---------------------------
# 4. 各モデル × 各テスト地域の評価
# ---------------------------
for model_key, model_params in fedprox_models.items():
    for test_region in unique_regl:
        # テストデータの抽出
        test_data = data[data['REGL'] == test_region].copy()
        X_test = test_data.drop(columns=['DAY30', 'REGL'])
        y_test = test_data['DAY30']

        # 特徴量の標準化（ここではテストデータに対してfitしています）
        scaler = StandardScaler()
        X_test_scaled = scaler.fit_transform(X_test)

        # FedProxモデルの係数・切片を取得
        coefs = np.array([model_params['coefficients'][col] for col in X_test.columns])
        intercept = model_params['intercept']
        
        # ---------------------------
        # 点推定値（全データでの計算）
        # ---------------------------
        logits_full = np.dot(X_test_scaled, coefs) + intercept
        y_pred_prob_full = 1 / (1 + np.exp(-logits_full))
        point_auc = roc_auc_score(y_test, y_pred_prob_full)
        
        frac_pos_full, mean_pred_val_full = calibration_curve(y_test, y_pred_prob_full, n_bins=10)
        if len(mean_pred_val_full) >= 2:
            point_slope, point_intercept_cal = np.polyfit(mean_pred_val_full, frac_pos_full, 1)
        else:
            point_slope, point_intercept_cal = np.nan, np.nan
        
        # ---------------------------
        # ブートストラップによる評価（1000回）
        # ---------------------------
        aucs, slopes, intercepts = [], [], []
        for i in range(1000):
            X_bs, y_bs = resample(X_test_scaled, y_test, random_state=i)
            logits = np.dot(X_bs, coefs) + intercept
            y_pred_prob = 1 / (1 + np.exp(-logits))
            
            # AUROCの計算
            aucs.append(roc_auc_score(y_bs, y_pred_prob))
            
            # キャリブレーションカーブから傾きと切片を計算
            frac_pos, mean_pred_val = calibration_curve(y_bs, y_pred_prob, n_bins=10)
            if len(mean_pred_val) >= 2:
                boot_slope, boot_intercept_cal = np.polyfit(mean_pred_val, frac_pos, 1)
            else:
                boot_slope, boot_intercept_cal = np.nan, np.nan
            slopes.append(boot_slope)
            intercepts.append(boot_intercept_cal)
        
        # 95%信頼区間 (2.5パーセンタイル・97.5パーセンタイル)
        auc_ci = np.percentile(aucs, [2.5, 97.5])
        slope_ci = np.percentile(slopes, [2.5, 97.5])
        intercept_ci = np.percentile(intercepts, [2.5, 97.5])
        
        key = f"test{test_region}_{model_key}"
        bootstrap_summary['AUROC'][key] = {
            'point': point_auc,
            'lower': auc_ci[0],
            'upper': auc_ci[1]
        }
        bootstrap_summary['CalibrationSlope'][key] = {
            'point': point_slope,
            'lower': slope_ci[0],
            'upper': slope_ci[1]
        }
        bootstrap_summary['CalibrationIntercept'][key] = {
            'point': point_intercept_cal,
            'lower': intercept_ci[0],
            'upper': intercept_ci[1]
        }

# ---------------------------
# 5. 結果のCSV出力（点推定値と95%CI）
# ---------------------------
for metric, results in bootstrap_summary.items():
    # 辞書形式の結果をDataFrameに変換
    df_metric = pd.DataFrame.from_dict(results, orient='index')
    df_metric.reset_index(inplace=True)
    df_metric.rename(columns={'index': 'Region_Model'}, inplace=True)
    
    # CSVへ保存
    csv_filename = f"{metric}_FedProx_64models_withCI.csv"
    df_metric.to_csv(csv_filename, index=False)
    print(f"{metric} results saved to {csv_filename}")
