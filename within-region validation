import pandas as pd
import numpy as np
from sklearn.model_selection import StratifiedKFold, GridSearchCV
from sklearn.linear_model import LogisticRegression
from sklearn.preprocessing import StandardScaler
from sklearn.metrics import roc_auc_score, average_precision_score, brier_score_loss
from sklearn.calibration import calibration_curve

# ---------------------------
# 1. データセットの読み込み
# ---------------------------
data = pd.read_csv('/content/GUSTO_sterberg.csv')
unique_regl = sorted(data['REGL'].unique())  # 地域1～16を取得

# 特徴量リスト（順番を統一）
feature_columns = ['SEX', 'AGE', 'KILLIP', 'DIA', 'HYP', 'HRT', 'ANT', 'PMI', 'HEI', 'WEI', 'SMK', 'HTN', 'LIP', 'PAN', 'FAM', 'STE', 'TTR']

# 追加モデルの係数と切片
coefficients = {
    'LASSO1': [0.0468, 0.7915, 0.3233, 0.0973, 0.3112, 0.2727, 0.1623, 0.1860, -0.0751, -0.1327, 0.0875, 0.0725, -0.0731, 0.0434, -0.0594, 0.1575, 0.2488],
    'Ridge1': [0.0486, 0.7868, 0.3236, 0.0979, 0.3108, 0.2717, 0.1624, 0.1860, -0.0722, -0.1358, 0.0891, 0.0730, -0.0736, 0.0443, -0.0604, 0.1580, 0.2477],
    'ElasticNet1': [0.0471, 0.7864, 0.3232, 0.0971, 0.3104, 0.2716, 0.1620, 0.1857, -0.0753, -0.1330, 0.0887, 0.0725, -0.0734, 0.0436, -0.0598, 0.1572, 0.2475],
    'NoRegularization1': [0.0479, 0.7912, 0.3234, 0.0974, 0.3116, 0.2733, 0.1622, 0.1862, -0.0738, -0.1338, 0.0879, 0.0730, -0.0737, 0.0438, -0.0599, 0.1576, 0.2495],
    'LASSO2': [0.0453, 0.7650, 0.3218, 0.0866, 0.2961, 0.2527, 0.1478, 0.1709, -0.0724, -0.1073, 0.0847, 0.0507, -0.0550, 0.0421, -0.0474, 0.1421, 0.2289],
    'Ridge2': [0.0541, 0.7035, 0.3210, 0.0967, 0.2966, 0.2515, 0.1566, 0.1787, -0.0740, -0.1306, 0.1132, 0.0633, -0.0766, 0.0467, -0.0663, 0.1483, 0.2339],
    'ElasticNet2': [0.0556, 0.7151, 0.3210, 0.0858, 0.2883, 0.2421, 0.1505, 0.1705, -0.0703, -0.1147, 0.1009, 0.0555, -0.0716, 0.0393, -0.0587, 0.1386, 0.2193],
    'NoRegularization2': [0.0538, 0.7986, 0.3292, 0.1007, 0.3147, 0.2735, 0.1626, 0.1873, -0.0667, -0.1288, 0.0975, 0.0625, -0.0740, 0.0446, -0.0639, 0.1577, 0.2606]
}
intercepts = {
    'LASSO1': -3.2662, 'Ridge1': -3.2650, 'ElasticNet1': -3.2629, 'NoRegularization1': -3.2671,
    'LASSO2': -3.2408, 'Ridge2': -3.2569, 'ElasticNet2': -3.2291, 'NoRegularization2': -3.3433
}

# 交差検証の結果を格納するリスト
cv_results = []

# 各地域ごとに5-fold cross-validationを実施
for regl in unique_regl:
    region_data = data[data['REGL'] == regl]
    X = region_data[feature_columns]
    y = region_data['DAY30']
    
    kf = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)
    
    for fold, (train_idx, test_idx) in enumerate(kf.split(X, y), 1):
        X_train, X_test = X.iloc[train_idx], X.iloc[test_idx]
        y_train, y_test = y.iloc[train_idx], y.iloc[test_idx]
        
        # 特徴量の標準化
        scaler = StandardScaler()
        X_train_scaled = scaler.fit_transform(X_train)
        X_test_scaled = scaler.transform(X_test)
        
        # 機械学習モデルの学習
        models = {
            'LASSO': GridSearchCV(
                LogisticRegression(max_iter=10000, penalty='l1', solver='liblinear'),
                param_grid={'C': np.logspace(-3, 3, 7)},
                cv=5, scoring='neg_log_loss'
            ).fit(X_train_scaled, y_train),
            'Ridge': GridSearchCV(
                LogisticRegression(max_iter=10000, penalty='l2', solver='lbfgs'),
                param_grid={'C': np.logspace(-3, 3, 7)},
                cv=5, scoring='neg_log_loss'
            ).fit(X_train_scaled, y_train),
            'ElasticNet': GridSearchCV(
                LogisticRegression(max_iter=10000, penalty='elasticnet', solver='saga'),
                param_grid={'C': np.logspace(-3, 3, 7), 'l1_ratio': [0.1, 0.5, 0.9]},
                cv=5, scoring='neg_log_loss'
            ).fit(X_train_scaled, y_train),
            'LogisticRegression': LogisticRegression(max_iter=10000, solver='lbfgs').fit(X_train_scaled, y_train)
        }
        
        # 機械学習モデルの評価
        for model_name, model in models.items():
            y_pred_prob = model.predict_proba(X_test_scaled)[:, 1]
            
            auroc = roc_auc_score(y_test, y_pred_prob)
            auprc = average_precision_score(y_test, y_pred_prob)
            brier = brier_score_loss(y_test, y_pred_prob)
            
            frac_pos, mean_pred_val = calibration_curve(y_test, y_pred_prob, n_bins=10)
            slope, intercept_calib = np.polyfit(mean_pred_val, frac_pos, 1)
            
            cv_results.append({
                'Region': regl,
                'Fold': fold,
                'Model': model_name,
                'AUROC': auroc,
                'AUPRC': auprc,
                'Brier': brier,
                'CalibrationSlope': slope,
                'CalibrationIntercept': intercept_calib
            })
        
        # 追加モデルを適用
        for model_name in coefficients.keys():
            coef_values = np.array(coefficients[model_name])
            intercept_val = intercepts[model_name]
            y_pred_prob = 1 / (1 + np.exp(-(X_test_scaled @ coef_values + intercept_val)))
            
            auroc = roc_auc_score(y_test, y_pred_prob)
            auprc = average_precision_score(y_test, y_pred_prob)
            brier = brier_score_loss(y_test, y_pred_prob)
            
            frac_pos, mean_pred_val = calibration_curve(y_test, y_pred_prob, n_bins=10)
            slope, intercept_calib = np.polyfit(mean_pred_val, frac_pos, 1)
            
            cv_results.append({
                'Region': regl,
                'Fold': fold,
                'Model': model_name,
                'AUROC': auroc,
                'AUPRC': auprc,
                'Brier': brier,
                'CalibrationSlope': slope,
                'CalibrationIntercept': intercept_calib
            })

# 結果をCSVに保存
pd.DataFrame(cv_results).to_csv('cross_validation_results.csv', index=False)

# モデルの係数を保存
# 係数リストは17個の値なので、まずは特徴量のみの DataFrame を作成し、
# その後に切片を別途追加する
coef_df = pd.DataFrame.from_dict(coefficients, orient='index', columns=feature_columns)
coef_df['Intercept'] = pd.Series(intercepts)
coef_df.to_csv('model_coefficients.csv', index=True)

print("Cross-validation results saved to cross_validation_results.csv")
print("Model coefficients saved to model_coefficients.csv")
